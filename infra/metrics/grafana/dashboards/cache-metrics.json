{
  "id": null,
  "uid": "cache-metrics",
  "title": "Cache Hit/Miss Metrics",
  "tags": ["happyheadlines", "cache"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cache Hits per Second",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(cache_hits_total{job=\"article-service\"}[1m])",
          "legendFormat": "article-service - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rate(cache_hits_total{job=\"comment-service\"}[1m])",
          "legendFormat": "comment-service - {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cache Misses per Second",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(cache_misses_total{job=\"article-service\"}[1m])",
          "legendFormat": "article-service - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rate(cache_misses_total{job=\"comment-service\"}[1m])",
          "legendFormat": "comment-service - {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache Hit Rate (%)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * rate(cache_hits_total{job=\"article-service\"}[1m]) / (rate(cache_hits_total{job=\"article-service\"}[1m]) + rate(cache_misses_total{job=\"article-service\"}[1m]))",
          "legendFormat": "article-service hit rate - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "100 * rate(cache_hits_total{job=\"comment-service\"}[1m]) / (rate(cache_hits_total{job=\"comment-service\"}[1m]) + rate(cache_misses_total{job=\"comment-service\"}[1m]))",
          "legendFormat": "comment-service hit rate",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "article-service — Total Cache Hits",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(cache_hits_total{job=\"article-service\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "article-service — Total Cache Misses",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(cache_misses_total{job=\"article-service\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "comment-service — Total Cache Hits",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(cache_hits_total{job=\"comment-service\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "comment-service — Total Cache Misses",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(cache_misses_total{job=\"comment-service\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
