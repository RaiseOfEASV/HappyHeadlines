# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# SQL files LF
*.sql text eol=lf

# Windows-only files can keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
