# Environment variables for subscriber-webapp
# Copy this file to .env for local development

# Article Service URL (used by Vite dev server proxy)
VITE_ARTICLE_SERVICE_URL=http://localhost:5200

# Comment Service URL (used by Vite dev server proxy)
VITE_COMMENT_SERVICE_URL=http://localhost:5542

# Subscriber Service URL (used by Vite dev server proxy)
VITE_SUBSCRIBER_SERVICE_URL=http://localhost:5500

# Note: In production (Docker), these are set in docker-compose.yml
# and nginx handles the proxying, not Vite
