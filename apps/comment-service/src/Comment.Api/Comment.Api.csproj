<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.3" />
    <!--
      Design package stays here so `dotnet ef` CLI works with this as the startup project.
      PrivateAssets=all ensures it is never published into the Docker image.
    -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.13">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Comment.Services\Comment.Services.csproj" />
    <ProjectReference Include="..\Comment.Data\Comment.Data.csproj" />
    <ProjectReference Include="..\Options\Options.csproj" />
  </ItemGroup>
</Project>