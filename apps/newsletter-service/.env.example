# PostgreSQL Configuration
POSTGRES_DB=newsletterdb
POSTGRES_USER=newsletteruser
POSTGRES_PASSWORD=newsletterpass

# Redis Configuration
REDIS_PASSWORD=redispass

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# SMTP Configuration
# For Gmail: use smtp.gmail.com, port 587, and an app password
# For SendGrid: use smtp.sendgrid.net, port 587
# For AWS SES: use email-smtp.region.amazonaws.com, port 587
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Observability
SEQ_API_KEY=
