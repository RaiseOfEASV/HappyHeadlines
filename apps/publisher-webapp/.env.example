# Environment variables for webapp-service
# Copy this file to .env for local development

# Draft Service URL (used by Vite dev server proxy)
VITE_DRAFT_SERVICE_URL=http://localhost:8080

# Publisher Service URL (used by Vite dev server proxy)
VITE_PUBLISHER_SERVICE_URL=http://localhost:8081

# Jaeger OTLP endpoint for OpenTelemetry traces
VITE_JAEGER_ENDPOINT=http://localhost:4318/v1/traces

# Note: In production (Docker), these are set in docker-compose.yml
# and nginx handles the proxying, not Vite
